{
  "$schema": "https://raw.githubusercontent.com/lit/localize-tools/main/config.schema.json",
  "sourceLocale": "id",
  "targetLocales": ["en", "es"],
  "inputFiles": [
    "src/js/**/*.js"
  ],
  "output": {
    "mode": "runtime",
    "outputDir": "./src/js/generated/locales",
    "localeCodesModule": "./src/js/generated/locale-codes.js"
  },
  "interchange": {
    "format": "xliff",
    "xliffDir": "./xliff/"
  }
}
